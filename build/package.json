{
  "name": "kyros-assets-build",
  "private": true,
  "version": "1.0.0",
  "description": "Compiles the self-hosted Tailwind CSS and bundles vendor assets for Kyros Rent Car.",
  "scripts": {
    "build": "tailwindcss -c tailwind.config.js -i input.css -o ../public/assets/css/tailwind.css --minify",
    "watch": "tailwindcss -c tailwind.config.js -i input.css -o ../public/assets/css/tailwind.css --watch"
  },
  "dependencies": {
    "tailwindcss": "3.4.17",
    "alpinejs": "3.14.8",
    "chart.js": "4.4.1",
    "lucide": "0.469.0",
    "gsap": "3.12.5",
    "aos": "2.3.4",
    "fullcalendar": "6.1.11",
    "@fontsource-variable/inter": "5.1.1",
    "@fontsource-variable/plus-jakarta-sans": "5.1.1"
  }
}
