# =====================================================================
# KYROS RENT CAR — Plantilla de variables de entorno
# Copia este archivo a `.env` y completa los valores reales.
# El `.env` real NO se versiona (está en .gitignore).
#
# Sin `.env`, la app usa los valores por defecto de XAMPP local:
#   KYROS_ENV=local, root@127.0.0.1, base de datos kyros_rentcar.
# =====================================================================

# local | production  (controla URLs en config/app.php y debug)
KYROS_ENV=production

# Credenciales de la base de datos
DB_HOST=tu-host-de-base-de-datos
DB_PORT=3306
DB_NAME=tu_base_de_datos
DB_USER=tu_usuario
DB_PASS=tu_password
