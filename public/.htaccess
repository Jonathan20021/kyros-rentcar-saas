# KYROS RENT CAR - public front controller routing
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve existing files/directories directly (assets, uploads).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else to index.php
    RewriteRule ^ index.php [L]
</IfModule>

# Security: deny access to dotfiles
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

Options -Indexes
